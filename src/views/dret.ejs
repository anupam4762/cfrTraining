<!DOCTYPE html>
<html>
<head>
    <title>DRET Training</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            background: #f4f6f8;
        }

        /* 🔹 Navbar */
        .header {
            background: linear-gradient(90deg, #4fa3b8, #5bbad5);
            color: white;
            padding: 18px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h2 {
            margin: 0;
        }

        .header a {
            color: white;
            margin-left: 15px;
            text-decoration: none;
            font-weight: 500;
        }

        /* 🔹 Hero Section */
        .hero {
            background: white;
            padding: 40px;
            text-align: center;
        }

        .hero h1 {
            font-weight: 600;
            margin-bottom: 10px;
        }

        .hero p {
            color: #555;
            max-width: 700px;
            margin: auto;
        }

        /* 🔹 Buttons */
        .top-buttons {
            display: flex;
            justify-content: center;
            gap: 15px;
            margin-top: 20px;
        }

        .btn-custom {
            padding: 10px 18px;
            border-radius: 6px;
            font-weight: 500;
            border: none;
            cursor: pointer;
        }

        .btn-back { background: #6c757d; color: white; }
        .btn-preview { background: #17a2b8; color: white; }
        .btn-download { background: #28a745; color: white; text-decoration: none; }

        /* 🔹 Sections */
        .container {
            padding: 40px;
        }

        .sections {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        /* 🔹 Cards */
        .card {
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0px 5px 20px rgba(0,0,0,0.08);
            transition: 0.25s;
            text-align: left;
        }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0px 10px 25px rgba(0,0,0,0.15);
        }

        .icon {
            width: 60px;
            height: 60px;
            background: #e9f2ff;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            color: #007bff;
            margin-bottom: 15px;
        }

        .card h3 {
            font-size: 18px;
            font-weight: 600;
        }

        .card p {
            font-size: 14px;
            color: #555;
            line-height: 1.6;
        }

        /* 🔹 Modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 999;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.7);
        }

        .modal-content {
            margin: 5% auto;
            width: 80%;
            height: 80%;
            background: white;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
        }

        .modal iframe {
            width: 100%;
            height: 100%;
        }

        .close-btn {
            position: absolute;
            top: 10px;
            right: 15px;
            font-size: 22px;
            cursor: pointer;
        }
    </style>
</head>

<body>

    <!-- 🔹 Header -->
    <div class="header">
        <h2>CFR Training Portal</h2>
        <div>
            <a href="/login">Login</a>
            <a href="/register">Register</a>
        </div>
    </div>

    <!-- 🔹 Hero Section -->
    <div class="hero">
        <h1>Design Reliability Engineering Training (DRET)</h1>
        <p>
            A comprehensive industry-oriented program covering reliability engineering principles,
            prediction techniques, statistical analysis, and failure assessment methods.
        </p>

        <!-- Buttons -->
        <div class="top-buttons">
            <button class="btn-custom btn-back" onclick="window.location.href='/'">⬅ Back</button>
            <button class="btn-custom btn-preview" onclick="openModal()">👁 Preview Brochure</button>
            <a href="/DRET_Brochure V 1.2.pdf" class="btn-custom btn-download" download>📄 Download Brochure</a>
        </div>
    </div>

    <!-- 🔹 Cards Section -->
    <div class="container">
        <div class="sections">

            <div class="card">
                <div class="icon"><i class="bi bi-bar-chart-line"></i></div>
                <h3>Reliability Engineering – Overview</h3>
                <p>Understand system lifecycle, reliability metrics, failure behavior, and maintainability concepts essential for engineering systems.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-graph-up-arrow"></i></div>
                <h3>Reliability Prediction</h3>
                <p>Estimate system reliability using MIL-HDBK-217 and Telcordia methods for real-world applications.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-calculator"></i></div>
                <h3>Statistics & Distributions</h3>
                <p>Analyze failure data using Weibull, exponential distributions and parameter estimation techniques.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-diagram-3"></i></div>
                <h3>System Modelling</h3>
                <p>Learn redundancy techniques and reliability block diagrams to improve system performance.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-exclamation-triangle"></i></div>
                <h3>FMECA</h3>
                <p>Identify failure modes, assess risks, and prioritize mitigation strategies.</p>
            </div>

            <div class="card">
                <div class="icon"><i class="bi bi-diagram-2"></i></div>
                <h3>Fault Tree Analysis</h3>
                <p>Perform root cause analysis using structured fault tree diagrams.</p>
            </div>

        </div>
    </div>

    <!-- 🔹 PDF Modal -->
    <div id="pdfModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" onclick="closeModal()">✖</span>
            <iframe src="/DRET_Brochure V 1.2.pdf"></iframe>
        </div>
    </div>

    <!-- 🔹 JS -->
    <script>
        function openModal() {
            document.getElementById("pdfModal").style.display = "block";
        }

        function closeModal() {
            document.getElementById("pdfModal").style.display = "none";
        }

        window.onclick = function(event) {
            const modal = document.getElementById("pdfModal");
            if (event.target === modal) {
                modal.style.display = "none";
            }
        }
    </script>

</body>
</html>
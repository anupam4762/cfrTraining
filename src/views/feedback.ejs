<!DOCTYPE html>
<html lang="en">
<head>
    <title>Feedback - CFR Training</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #eef2f7, #dfe9f3);
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }

        /* Header */
        .header {
            background: linear-gradient(90deg, #4fa3b8, #5bbad5);
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Container */
        .main-container {
            display: flex;
            justify-content: center;
            padding: 40px 20px;
        }

        /* Card */
        .feedback-card {
            width: 100%;
            max-width: 700px;
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            animation: fadeSlide 0.6s ease;
        }

        .feedback-title {
            text-align: center;
            margin-bottom: 25px;
        }

        /* Inputs */
        .form-control, .form-select {
            border-radius: 10px;
            padding: 10px;
        }

        .form-control:focus, .form-select:focus {
            border-color: #4fa3b8;
            box-shadow: 0 0 0 0.2rem rgba(79,163,184,0.25);
            transform: scale(1.02);
        }

        /* Rating */
        .rating {
            display: flex;
            gap: 10px;
            font-size: 28px;
            cursor: pointer;
        }

        .rating i {
            color: #ddd;
            transition: transform 0.2s, color 0.2s;
        }

        .rating i:hover {
            transform: scale(1.3);
        }

        .rating i.active {
            color: #ffc107;
            transform: scale(1.2);
        }

        /* Button */
        .btn-submit {
            background: linear-gradient(90deg, #4fa3b8, #5bbad5);
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 500;
            position: relative;
            overflow: hidden;
        }

        .btn-submit:hover {
            opacity: 0.9;
        }

        /* Animation */
        @keyframes fadeSlide {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Success Modal */
        .success-modal {
            display: none;
            position: fixed;
            z-index: 999;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            top: 0;
            left: 0;
            justify-content: center;
            align-items: center;
        }

        .success-box {
            background: white;
            padding: 30px;
            border-radius: 12px;
            text-align: center;
            animation: pop 0.4s ease;
        }

        .checkmark {
            font-size: 40px;
            color: #28a745;
        }

        @keyframes pop {
            from { transform: scale(0.7); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
    </style>
</head>

<body>

<!-- Header -->
<div class="header">
    <h4>CFR Training Portal</h4>

    <div>
        <span class="me-3">👤 <%= typeof user !== 'undefined' ? user.name : 'User' %></span>

        <button class="btn btn-light btn-sm"
            onclick="window.location.href='/dashboard'">
            Dashboard
        </button>

        <button class="btn btn-light btn-sm ms-2"
            onclick="window.location.href='/logout'">
            Logout
        </button>
    </div>
</div>

<!-- Form -->
<div class="main-container">

    <div class="feedback-card">

        <h3 class="feedback-title">💬 Submit Feedback</h3>

        <form id="feedbackForm" method="POST" action="/submit-feedback">

            <!-- Course -->
            <div class="mb-3">
                <label class="form-label">Course</label>
                <select class="form-select" name="course" required>
                    <option value="">Select Course</option>
                    <option>DRET</option>
                    <option>CFR</option>
                </select>
            </div>

            <!-- Rating -->
            <div class="mb-3">
                <label class="form-label">Overall Rating</label>

                <div class="rating" id="rating">
                    <i class="bi bi-star-fill" data-value="1"></i>
                    <i class="bi bi-star-fill" data-value="2"></i>
                    <i class="bi bi-star-fill" data-value="3"></i>
                    <i class="bi bi-star-fill" data-value="4"></i>
                    <i class="bi bi-star-fill" data-value="5"></i>
                </div>

                <input type="hidden" name="rating" id="ratingValue" required>
            </div>

            <!-- Feedback -->
            <div class="mb-3">
                <label class="form-label">Your Feedback</label>
                <textarea class="form-control" name="feedback" rows="4" placeholder="Share your experience..." required></textarea>
            </div>

            <!-- Suggestions -->
            <div class="mb-3">
                <label class="form-label">Suggestions (Optional)</label>
                <textarea class="form-control" name="suggestions" rows="3" placeholder="Any improvements?"></textarea>
            </div>

            <button type="submit" class="btn btn-submit w-100">
                Submit Feedback
            </button>

        </form>

    </div>

</div>

<!-- Success Modal -->
<div id="successModal" class="success-modal">
    <div class="success-box">
        <div class="checkmark">✔</div>
        <h4>Feedback Submitted!</h4>
        <p>Thank you for your input 🙌</p>
    </div>
</div>

<script>

// ⭐ Star Rating
const stars = document.querySelectorAll("#rating i");
const ratingValue = document.getElementById("ratingValue");

stars.forEach(star => {

    star.addEventListener("mouseover", function () {
        let val = this.getAttribute("data-value");

        stars.forEach(s => s.classList.remove("active"));

        for (let i = 0; i < val; i++) {
            stars[i].classList.add("active");
        }
    });

    star.addEventListener("click", function () {
        let val = this.getAttribute("data-value");
        ratingValue.value = val;

        stars.forEach(s => s.classList.remove("active"));

        for (let i = 0; i < val; i++) {
            stars[i].classList.add("active");
        }
    });

});

document.getElementById("rating").addEventListener("mouseleave", function () {
    stars.forEach(s => s.classList.remove("active"));

    let val = ratingValue.value;

    for (let i = 0; i < val; i++) {
        stars[i].classList.add("active");
    }
});

// ✅ Submit with animation
const form = document.getElementById("feedbackForm");

form.addEventListener("submit", function(e) {
    e.preventDefault();

    if (!ratingValue.value) {
        alert("Please select rating ⭐");
        return;
    }

    const modal = document.getElementById("successModal");
    modal.style.display = "flex";

    setTimeout(() => {
        form.submit();
    }, 1500);
});

</script>

</body>
</html>
<!DOCTYPE html>
<html>
<head>
    <title>CFR Training</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            margin-top: 100px;
            background-color: #f4f6f8;
        }

        h1 {
            margin-bottom: 40px;
        }

        .btn-container {
            display: flex;
            justify-content: center;
            gap: 20px;
        }

        .btn {
            padding: 15px 40px;
            font-size: 18px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            color: white;
            transition: 0.3s;
        }

        .btn-dret {
            background-color: #007bff;
        }

        .btn-cfr {
            background-color: #28a745;
        }

        .btn:hover {
            opacity: 0.8;
        }
    </style>
</head>

<body>

    <h1>CFR Training System 🚀</h1>

    <div class="btn-container">
        <button class="btn btn-dret" onclick="window.location.href='/dret'">DRET</button>
        <button class="btn btn-cfr">CFR</button>
    </div>

<script>
localStorage.clear();
</script>

</body>
</html>
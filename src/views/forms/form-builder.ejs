<!DOCTYPE html>
<html>
<head>
    <title>Dynamic Form Builder</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Header */
        .header {
            background: linear-gradient(90deg, #673ab7, #7e57c2);
            color: white;
            padding: 15px 30px;

            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Container */
        .builder-container {
            max-width: 900px;
            margin: 30px auto;
        }

        /* Top Form Card */
        .form-top-card {
            background: white;
            border-top: 8px solid #673ab7;

            border-radius: 10px;

            padding: 30px;

            margin-bottom: 25px;

            box-shadow: 0 3px 10px rgba(0,0,0,0.08);
        }

        /* Question Card */
        .question-card {
            background: white;

            border-radius: 10px;

            padding: 25px;

            margin-bottom: 20px;

            box-shadow: 0 3px 10px rgba(0,0,0,0.08);

            position: relative;
        }

        .question-input {
            border: none;
            border-bottom: 2px solid #ddd;
            border-radius: 0;
            font-size: 18px;
        }

        .question-input:focus {
            box-shadow: none;
            border-color: #673ab7;
        }

        .option-row {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .add-option-btn {
            margin-top: 10px;
        }

        .question-actions {
            margin-top: 20px;
            display: flex;
            justify-content: space-between;
        }

        .add-question-btn {
            position: fixed;
            right: 40px;
            bottom: 40px;

            width: 65px;
            height: 65px;

            border-radius: 50%;

            font-size: 28px;

            border: none;

            background: #673ab7;
            color: white;

            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        .save-btn {
            background: #673ab7;
            border: none;
        }

        .save-btn:hover {
            background: #5e35b1;
        }

        .required-star {
            color: red;
        }

    </style>
</head>

<body>

<!-- Header -->
<div class="header">

    <h4>CFR Training Portal</h4>

    <button class="btn btn-light"
        onclick="window.location.href='/dashboard'">
        Dashboard
    </button>

</div>

<div class="builder-container">

<form method="POST"
      action="/save-form"
      enctype="multipart/form-data">

    <!-- Form Details -->
    <div class="form-top-card">

        <input type="text"
            class="form-control question-input mb-3"
            name="form_title"
            placeholder="Form Title"
            required>

        <textarea
            class="form-control"
            name="form_description"
            rows="3"
            placeholder="Form Description"></textarea>

    </div>

    <!-- Questions Container -->
    <div id="questionsContainer"></div>

    <!-- Save -->
    <button class="btn btn-success save-btn px-4 py-2">
        💾 Save Form
    </button>

</form>

</div>

<!-- Floating Add Button -->
<button class="add-question-btn"
    onclick="addQuestion()">

    +
</button>

<script>

let questionCount = 0;

function addQuestion() {

    const container =
        document.getElementById("questionsContainer");

    const html = `

<div class="question-card" id="question_${questionCount}">

    <!-- Question -->
    <div class="mb-3">

        <input type="text"
            class="form-control question-input"

            name="questions[${questionCount}][question]"

            placeholder="Question"

            required>

    </div>

    <!-- Type -->
    <div class="mb-3">

        <select class="form-select"

            name="questions[${questionCount}][type]"

            onchange="changeType(${questionCount}, this.value)">

            <option value="mcq">Multiple Choice</option>

            <option value="checkbox">
                Checkboxes
            </option>

            <option value="text">
                Short Answer
            </option>

            <option value="paragraph">
                Paragraph
            </option>

        </select>

    </div>

    <!-- Add Image Button -->
    <button type="button"

        class="btn btn-outline-secondary btn-sm"

        onclick="toggleImageUpload(${questionCount})">

        🖼 Add Image

    </button>

    <!-- Hidden Image Upload -->
    <div class="mt-3"

        id="imageUpload_${questionCount}"

        style="display:none;">

        <input type="file"

            class="form-control"

            name="question_image_${questionCount}">

    </div>

    <!-- Options -->
    <div id="options_${questionCount}" class="mt-3">

        <div class="option-row">

            <input type="text"

                class="form-control"

                name="questions[${questionCount}][options][]"

                placeholder="Option 1">

            <input type="checkbox"

                name="questions[${questionCount}][correct][]"

                value="0">

            Correct

        </div>

        <div class="option-row">

            <input type="text"

                class="form-control"

                name="questions[${questionCount}][options][]"

                placeholder="Option 2">

            <input type="checkbox"

                name="questions[${questionCount}][correct][]"

                value="1">

            Correct

        </div>

    </div>

    <!-- Add Option -->
    <button type="button"

        class="btn btn-outline-primary btn-sm add-option-btn"

        onclick="addOption(${questionCount})">

        ➕ Add Option

    </button>

    <!-- Footer -->
    <div class="question-actions">

        <div>

            <input type="checkbox"

                name="questions[${questionCount}][required]">

            Required

        </div>

        <button type="button"

            class="btn btn-outline-danger btn-sm"

            onclick="removeQuestion(${questionCount})">

            🗑 Delete

        </button>

    </div>

</div>
`;
    container.insertAdjacentHTML("beforeend", html);

    questionCount++;
}

function toggleImageUpload(index) {

    const div =
        document.getElementById(`imageUpload_${index}`);

    if (div.style.display === "none") {

        div.style.display = "block";

    } else {

        div.style.display = "none";
    }
}

function addOption(qIndex) {

    const optionsDiv =
        document.getElementById(`options_${qIndex}`);

    const optionCount =
        optionsDiv.querySelectorAll(".option-row").length;

    const html = `

    <div class="option-row">

        <input type="text"

            class="form-control"

            name="questions[${qIndex}][options][]"

            placeholder="Option ${optionCount + 1}">

        <input type="checkbox"

            name="questions[${qIndex}][correct][]"

            value="${optionCount}">

        Correct

    </div>

    `;

    optionsDiv.insertAdjacentHTML("beforeend", html);
}

function removeQuestion(index) {

    document
        .getElementById(`question_${index}`)
        .remove();
}

function changeType(index, type) {

    const optionsDiv =
        document.getElementById(`options_${index}`);

    if (type === "text" || type === "paragraph") {

        optionsDiv.innerHTML = `

            <div class="alert alert-light border">

                No options required for this
                question type.

            </div>
        `;
    }
}

addQuestion();

</script>

</body>
</html>
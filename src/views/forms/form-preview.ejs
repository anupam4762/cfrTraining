<!DOCTYPE html>
<html>
<head>
    <title><%= form.title %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
        }

        .form-container {

            max-width: 850px;

            margin: 40px auto;
        }

        .form-header {

            background: white;

            border-top: 8px solid #673ab7;

            padding: 30px;

            border-radius: 12px;

            margin-bottom: 25px;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);
        }

        .question-card {

            background: white;

            padding: 25px;

            border-radius: 12px;

            margin-bottom: 20px;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);
        }

        .question-title {

            font-size: 18px;

            font-weight: 600;

            margin-bottom: 15px;
        }

        .question-image {

            width: 100%;

            max-height: 300px;

            object-fit: contain;

            margin-bottom: 15px;

            border-radius: 10px;
        }

        .submit-btn {

            background: #673ab7;

            border: none;
        }

        .submit-btn:hover {

            background: #5e35b1;
        }

    </style>
</head>

<body>

<div class="form-container">

<form method="POST" action="/submit-form/<%= form.id %>">

    <!-- Form Header -->
    <div class="form-header">

        <h2><%= form.title %></h2>

        <p>
            <%= form.description || '' %>
        </p>

    </div>

    <!-- Questions -->
    <% questions.forEach((q, index) => { %>

        <div class="question-card">

            <div class="question-title">

                Q<%= index + 1 %>.
                <%= q.question %>

            </div>

            <!-- Image -->
            <% if (q.image_url) { %>

                <img
                    src="<%= q.image_url %>"
                    class="question-image">

            <% } %>

            <!-- MCQ -->
            <% if (q.question_type === 'mcq') { %>

                <% q.options.forEach(opt => { %>

                    <div class="form-check mb-2">

                        <input
                            class="form-check-input"

                            type="radio"

                            name="q_<%= q.id %>"

                            value="<%= opt.option_text %>">

                        <label class="form-check-label">

                            <%= opt.option_text %>

                        </label>

                    </div>

                <% }) %>

            <% } %>

            <!-- Checkbox -->
            <% if (q.question_type === 'checkbox') { %>

                <% q.options.forEach(opt => { %>

                    <div class="form-check mb-2">

                        <input
                            class="form-check-input"

                            type="checkbox"

                            name="q_<%= q.id %>[]"

                            value="<%= opt.option_text %>">

                        <label class="form-check-label">

                            <%= opt.option_text %>

                        </label>

                    </div>

                <% }) %>

            <% } %>

            <!-- Short Text -->
            <% if (q.question_type === 'text') { %>

                <input
                    type="text"

                    class="form-control"

                    name="q_<%= q.id %>">

            <% } %>

            <!-- Paragraph -->
            <% if (q.question_type === 'paragraph') { %>

                <textarea
                    class="form-control"

                    rows="4"

                    name="q_<%= q.id %>"></textarea>

            <% } %>

        </div>

    <% }) %>

    <!-- Submit -->
    <button class="btn btn-primary submit-btn px-4 py-2">

        🚀 Submit Form

    </button>

</form>

</div>

</body>
</html>
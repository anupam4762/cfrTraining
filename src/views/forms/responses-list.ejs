<!DOCTYPE html>
<html>
<head>
    <title>Responses</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
        }

        .container-box {

            max-width: 1100px;

            margin: 40px auto;
        }

        .top-card {

            background: white;

            padding: 30px;

            border-radius: 12px;

            margin-bottom: 25px;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);
        }

        .response-card {

            background: white;

            padding: 20px;

            border-radius: 12px;

            margin-bottom: 15px;

            display: flex;

            justify-content: space-between;

            align-items: center;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);
        }

    </style>
</head>

<body>

<div class="container-box">

    <!-- Header -->
    <div class="top-card">

        <h2><%= form.title %></h2>

        <p>
            Total Responses:
            <b><%= responses.length %></b>
        </p>

    </div>

    <!-- Responses -->
    <% if (responses.length === 0) { %>

        <div class="alert alert-light border">

            No responses yet.

        </div>

    <% } else { %>

        <% responses.forEach((r, index) => { %>

            <div class="response-card">

                <div>

                    <h5>
                        Response #<%= index + 1 %>
                    </h5>

                    <div>

                        User:
                        <%= r.user_email || 'Anonymous' %>

                    </div>

                    <div>

                        Submitted:
                        <%= new Date(r.submitted_at)
                            .toLocaleString() %>

                    </div>

                </div>

                <button class="btn btn-primary"

                    onclick="window.location.href='/response/<%= r.id %>'">

                    👁 View

                </button>

            </div>

        <% }) %>

    <% } %>

</div>

</body>
</html>
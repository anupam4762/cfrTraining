<!DOCTYPE html>
<html>
<head>
    <title>View Response</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
        }

        .container-box {

            max-width: 900px;

            margin: 40px auto;
        }

        .answer-card {

            background: white;

            padding: 25px;

            border-radius: 12px;

            margin-bottom: 20px;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);
        }

        .question {

            font-weight: 600;

            margin-bottom: 10px;
        }

        .answer {

            background: #f8f9fa;

            padding: 15px;

            border-radius: 8px;
        }

    </style>
</head>

<body>

<div class="container-box">

    <h2 class="mb-4">

        📄 Submitted Response

    </h2>

    <% answers.forEach((a, index) => { %>

        <div class="answer-card">

            <div class="question">

                Q<%= index + 1 %>.
                <%= a.question %>

            </div>

            <div class="answer">

                <%= a.answer_text || 'No Answer' %>

            </div>

        </div>

    <% }) %>

</div>

</body>
</html>
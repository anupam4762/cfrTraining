<!DOCTYPE html>
<html>
<head>
    <title>Forms</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

        body {
            background: #f0f2f5;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Header */
        .header {
            background: linear-gradient(90deg, #673ab7, #7e57c2);

            color: white;

            padding: 15px 30px;

            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .container-box {
            max-width: 1100px;
            margin: 40px auto;
        }

        .top-actions {
            display: flex;
            justify-content: space-between;
            margin-bottom: 25px;
        }

        .form-grid {
            display: grid;

            grid-template-columns:
                repeat(auto-fit, minmax(320px, 1fr));

            gap: 20px;
        }

        .form-card {

            background: white;

            border-radius: 12px;

            padding: 20px;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);

            transition: 0.2s;
        }

        .form-card:hover {

            transform: translateY(-5px);

            box-shadow:
                0 8px 20px rgba(0,0,0,0.12);
        }

        .form-title {

            font-size: 20px;

            font-weight: 600;

            margin-bottom: 10px;
        }

        .form-description {

            color: #666;

            min-height: 60px;
        }

        .form-date {

            font-size: 13px;

            color: #999;
        }

        .form-actions {

            margin-top: 20px;

            display: flex;

            gap: 10px;
        }

        .empty-box {

            background: white;

            padding: 40px;

            border-radius: 12px;

            text-align: center;

            box-shadow:
                0 4px 15px rgba(0,0,0,0.08);
        }

    </style>
</head>

<body>

<!-- Header -->
<div class="header">

    <h4>CFR Training Portal</h4>

    <button class="btn btn-light"

        onclick="window.location.href='/dashboard'">

        Dashboard

    </button>

</div>

<div class="container-box">

    <!-- Top -->
    <div class="top-actions">

        <h2>📋 Forms</h2>

        <button class="btn btn-primary"

            onclick="window.location.href='/form-builder'">

            ➕ Create Form

        </button>

    </div>

    <% if (forms.length === 0) { %>

        <div class="empty-box">

            <h4>No Forms Created</h4>

            <p>Create your first form.</p>

        </div>

    <% } else { %>

        <div class="form-grid">

            <% forms.forEach(form => { %>

                <div class="form-card">

                    <div class="form-title">
                        <%= form.title %>
                    </div>

                    <div class="form-description">

                        <%= form.description || 'No description' %>

                    </div>

                    <div class="form-date">

                        Created:
                        <%= new Date(form.created_at)
                            .toLocaleString() %>

                    </div>

                    <div class="form-actions">

                        <button class="btn btn-success btn-sm"

                            onclick="window.location.href='/form/<%= form.id %>'">

                            👁 Preview

                        </button>

                        <button class="btn btn-dark btn-sm"

                            onclick="window.location.href='/responses/<%= form.id %>'">

                            📊 Responses

                        </button>

                        <button class="btn btn-warning btn-sm">

                            ✏ Edit

                        </button>

                        <button class="btn btn-danger btn-sm"

                            onclick="deleteForm(<%= form.id %>)">

                            🗑 Delete

                        </button>


                    </div>

                </div>

            <% }) %>

        </div>

    <% } %>

</div>

<script>

function deleteForm(id) {

    if (confirm("Delete this form?")) {

        window.location.href =
            '/delete-form/' + id;
    }
}

</script>

</body>
</html>
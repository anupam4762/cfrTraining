<!DOCTYPE html>
<html lang="en">
<head>
    <title>Dashboard - CFR Training</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #6dd5ed, #2193b0);
            min-height: 100vh;
            margin: 0;
        }

        /* Header */
        .header {
            background: rgba(0,0,0,0.2);
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .header h4 {
            margin: 0;
        }

        /* Main Card */
        .main-container {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 85vh;
        }

        .card {
            padding: 40px;
            border-radius: 15px;
            text-align: center;
            width: 400px;
        }

        .btn-custom {
            width: 220px;
            padding: 15px;
            font-size: 18px;
            margin: 10px;
            border-radius: 10px;
        }

        .welcome-text {
            font-size: 20px;
            margin-bottom: 10px;
        }

        .sub-text {
            color: gray;
            font-size: 14px;
            margin-bottom: 25px;
        }
    </style>
</head>

<body>

    <!-- 🔹 Header -->
    <div class="header">
        <h4>CFR Training Portal</h4>

        <div>
            <button class="btn btn-light btn-sm"
                onclick="window.location.href='/logout'">
                Logout
            </button>
        </div>
    </div>

    <!-- 🔹 Main Content -->
    <div class="main-container">

        <div class="card shadow-lg">

            <div class="welcome-text">
                Welcome, <b><%= user?.name || 'User' %></b> 👋
            </div>

            <div class="sub-text">
                Choose an action to continue
            </div>

            <div>
                <button class="btn btn-primary btn-custom"
                    onclick="window.location.href='/test'">
                    📝 Give Test
                </button>

                <button class="btn btn-success btn-custom"
                    onclick="window.location.href='/feedback'">
                    💬 Submit Feedback
                </button>
            </div>

        </div>

    </div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Login - CFR Training</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #28a745, #6dd5ed);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .card {
            border-radius: 15px;
            padding: 25px;
        }

        .btn-custom {
            border-radius: 8px;
            padding: 10px;
            font-weight: 500;
        }

        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
        }
    </style>
</head>

<body>

    <!-- Back Button -->
    <button class="btn btn-light back-btn" onclick="window.location.href='/dret'">⬅ Back</button>

    <div class="card shadow-lg col-md-4">
        <h3 class="text-center mb-4">🔐 Login</h3>

        <form method="POST" action="/login">

            <div class="mb-3">
                <input type="email" name="personal_email" class="form-control" placeholder="Personal Email ID" required>
            </div>

            <div class="mb-4">
                <input type="password" name="password" class="form-control" placeholder="Password" required>
            </div>

            <button type="submit" class="btn btn-success w-100 btn-custom">
                Login
            </button>

        </form>
    </div>

</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <title>Register - CFR Training</title>

    <!-- Bootstrap + Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #4fa3b8, #5bbad5);
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
        }

        /* 🔹 Header */
        .header {
            background: rgba(0,0,0,0.2);
            color: white;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* 🔹 Container */
        .main-container {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px 15px;
        }

        /* 🔹 Card */
        .form-card {
            width: 100%;
            max-width: 700px;
            background: white;
            border-radius: 16px;
            padding: 35px;
            box-shadow: 0px 10px 30px rgba(0,0,0,0.2);
        }

        .form-title {
            text-align: center;
            margin-bottom: 25px;
            font-weight: 600;
        }

        /* 🔹 Inputs */
        .form-control {
            border-radius: 10px;
            padding: 12px;
            border: 1px solid #ddd;
        }

        .form-control:focus {
            border-color: #4fa3b8;
            box-shadow: 0 0 0 0.2rem rgba(79,163,184,0.2);
        }

        /* 🔹 Buttons */
        .btn-custom {
            border-radius: 10px;
            padding: 12px;
            font-weight: 500;
        }

        .btn-register {
            background: linear-gradient(90deg, #4fa3b8, #5bbad5);
            border: none;
        }

        .btn-register:hover {
            opacity: 0.9;
        }

        /* 🔹 Back Button */
        .back-btn {
            background: white;
            border-radius: 8px;
            padding: 6px 12px;
            border: none;
        }

        /* Success Modal */
        .success-modal {
            display: none;
            position: fixed;
            z-index: 999;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            top: 0;
            left: 0;
            justify-content: center;
            align-items: center;
        }

        .success-box {
            background: white;
            padding: 30px;
            border-radius: 12px;
            text-align: center;
            animation: pop 0.4s ease;
        }

        .checkmark {
            font-size: 40px;
            color: green;
            margin-bottom: 10px;
        }

        @keyframes pop {
            from { transform: scale(0.7); opacity: 0; }
            to { transform: scale(1); opacity: 1; }
        }
    </style>
</head>

<body>

    <!-- 🔹 Header -->
    <div class="header">
        <h4>CFR Training Portal</h4>

        <button class="back-btn" onclick="history.back()">
            ⬅ Back
        </button>
    </div>

    <!-- 🔹 Form -->
    <div class="main-container">

        <div class="form-card">

            <h3 class="form-title">📝 Registration Form</h3>

            <form method="POST" action="/register">

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input type="text" name="name" class="form-control" placeholder="Full Name" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <input type="text" name="designation" class="form-control" placeholder="Designation" required>
                    </div>
                </div>

                <div class="mb-3">
                    <input type="text" name="lab" class="form-control" placeholder="Lab Name" required>
                </div>

                <div class="mb-3">
                    <textarea name="lab_address" class="form-control" rows="2" placeholder="Lab Address" required></textarea>
                </div>

                <div class="mb-3">
                    <input type="text" name="mobile" class="form-control" placeholder="Mobile Number" required>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input type="email" name="official_email" class="form-control" placeholder="Official Email ID" required>
                    </div>

                    <div class="col-md-6 mb-3">
                        <input type="email" name="personal_email" class="form-control" placeholder="Personal Email ID" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <input type="password" name="password" class="form-control" placeholder="Password" required>
                    </div>

                    <div class="col-md-6 mb-4">
                        <input type="password" name="confirm_password" class="form-control" placeholder="Confirm Password" required>
                    </div>
                </div>

                <button type="submit" class="btn btn-register w-100 btn-custom">
                    Register
                </button>

                <div class="text-center mt-3">
                    <span style="color:#555;">Already have an account?</span>
                    <a href="/login" style="text-decoration:none; font-weight:500;">
                        Login
                    </a>
                </div>

            </form>

        </div>

    </div>

    <!-- Success Modal -->
    <div id="successModal" class="success-modal">
        <div class="success-box">
            <div class="checkmark">✔</div>
            <h4>Registration Successful</h4>
            <p>Redirecting to dashboard...</p>
        </div>
    </div>


</body>
</html>

<script>
window.onload = function () {
    if (localStorage.getItem("registerSuccess")) {

        localStorage.removeItem("registerSuccess");

        const modal = document.getElementById("successModal");
        modal.style.display = "flex";

        setTimeout(() => {
            window.location.href = "/dashboard";
        }, 2000);
    }
};
</script>